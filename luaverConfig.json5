{
    pluginName: "plumoguSV",                    // Also exposed to the PLUGIN_NAME global in Lua.
    pluginVersion: "2.2.1",                    // Also exposed to the PLUGIN_VERSION global in Lua.
    pluginAuthor: "plummyyummy, kloi34",        // Also exposed to the PLUGIN_AUTHOR global in Lua.
    pluginDescription: "The ultimate community-driven and open-source competitive SV plugin, remastered for the modern age.",                                          // Also exposed to the PLUGIN_DESCRIPTION global in Lua.
    includeVersionInPluginName: false,          // If true, will put the version into the plugin name in the settings.ini file.
    buildVersionInPluginName: true,             // If true, will put the version into the build name in the settings.ini file.
    sources: ["QParcel", "src"],                // Folders which should be included in the final plugin.
    outDir: "/",                                // Output location with respect to Luaver root.
    lineSeparator: "\n",                        // Consistent line separator for the plugin.
    dontRandomizeSeed: false,                   // If true, omits the math.randomseed(os.time()) line at the top of the plugin.
    workshopFolder: "assets"
}
