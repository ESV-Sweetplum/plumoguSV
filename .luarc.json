{
    "addonManager.enable": false,
    "codeLens.enable": true,
    "diagnostics.disable": [
        "lowercase-global",
        "duplicate-set-field",
        "duplicate-doc-alias",
        "unused-local",
        "duplicate-doc-field"
    ],
    "diagnostics.globals": [
        "PLUGIN_NAME",
        "PLUGIN_AUTHOR",
        "PLUGIN_VERSION",
        "PLUGIN_DESCRIPTION",
        "ENVIRONMENT",
        "DISTRO",
        "imgui_disable_vector_packing"
    ],
    "diagnostics.groupSeverity": {
        "ambiguity": "Error",
        "await": "Error",
        "codestyle": "Error",
        "conventions": "Fallback",
        "duplicate": "Warning",
        "global": "Fallback",
        "luadoc": "Warning",
        "redefined": "Fallback",
        "strict": "Error",
        "strong": "Warning",
        "type-check": "Error",
        "unbalanced": "Error",
        "unused": "Warning"
    },
    "diagnostics.libraryFiles": "Disable",
    "format.enable": false,
    "runtime.version": "Lua 5.2",
    "type.castNumberToInteger": true,
    "type.checkTableShape": true,
    "type.inferParamType": true,
    "workspace.ignoreDir": [
        ".vscode",
        "plugin.lua"
    ],
    "workspace.ignoreSubmodules": false,
    "workspace.library": [
        "intellisense.lua"
    ],
    "workspace.useGitIgnore": true
}