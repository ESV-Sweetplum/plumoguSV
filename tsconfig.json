{
    "compilerOptions": {
        "module": "commonjs",
        "rootDir": "Luaver/src",
        "outDir": "dist",
        "strict": true,
        "types": ["node"],
        "esModuleInterop": true,
        "lib": ["ES2024"],
        "target": "es6",
        "tsBuildInfoFile": "./dist/tsconfigRoot.tsbuildinfo"
    },
    "include": [
        "Luaver/src/**/*"
    ],
    "references": [
        {"path": "modules"}
    ]
}
